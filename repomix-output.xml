<!-- ANNOUNCEMENTS PAGE -->
<div id="page-announcements" class="page">
  <div class="section">
    <div class="section-heading">
      <div class="section-icon">📢</div>
      <div>
        <h2>Announcements &amp; Events</h2>
        <p>Latest updates from the Computer Science Department</p>
      </div>
    </div>

    <div class="announcement-list">
      {% if announcements %}
      {% for ann in announcements %}
      <div class="announcement-card {{ ann.category }}">
        <div class="ann-meta">
          <span class="ann-badge badge-{{ ann.category }}">
            {% if ann.category == 'urgent' %}🔴 Urgent{% elif ann.category == 'event' %}📅 Event{% else %}📋 Notice{% endif %}
          </span>
          <span class="ann-date">Set on: {{ ann.date }}</span>
        </div>
        <div class="ann-title">{{ ann.title }}</div>
        <div class="ann-body">{{ ann.content }}</div>
